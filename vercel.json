{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ],
  "crons": [
    {
      "path": "/api/cron/process-batches",
      "schedule": "0 0 * * *"
    }
  ],
  "functions": {
    "api/reenrich.js": { "maxDuration": 60 },
    "api/enrich.js": { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
